{
  "name": "url-shortener",
  "version": "0.0.1",
  "private": true,
  "description": "A simple Node.js app for shortening a URL",
  "homepage": "https://github.com/amoinier/url-shortener#readme",
  "bugs": {
    "url": "https://github.com/amoinier/url-shortener/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amoinier/url-shortener.git"
  },
  "license": "MIT",
  "author": "amoinier",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "start:debug": "tsx watch --inspect src/main.ts",
    "lint": "standard 'src/**/*.ts' 'test/**/*.ts'",
    "lint:fix": "standard --fix 'src/**/*.ts' 'test/**/*.ts'",
    "test": "jest --testPathPatterns='src/'",
    "test:e2e": "jest --testPathPatterns='test/'",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "nanoid": "^5.1.6",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "standard": "^17.1.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "standard": {
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint",
      "prettier"
    ],
    "extends": [
      "prettier"
    ],
    "globals": [
      "describe",
      "it",
      "expect",
      "jest",
      "beforeEach",
      "afterEach",
      "beforeAll",
      "afterAll"
    ],
    "rules": {
      "prettier/prettier": "error",
      "no-unused-vars": "off",
      "@typescript-eslint/no-unused-vars": "error"
    }
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*/(test|src)/.*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  }
}
